# The Anthropic key lives ONLY here on the server — never in the mobile app.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Used to verify the Supabase JWT sent by the mobile app.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Comma-separated list of allowed origins (optional; Expo dev clients send no origin).
ALLOWED_ORIGINS=

PORT=3001

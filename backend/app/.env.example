# API keys required for Expo app flows
GOOGLE_API_KEY=your-google-gemini-key
GEMINI_MODEL=gemini-2.5-flash

BROWSERBASE_API_KEY=your-browserbase-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_IP=604800
CACHE_TTL_MUNICIPAL_RULES=86400
CACHE_TTL_DISPOSAL_OPTIONS=43200

EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072
VECTOR_DISTANCE_THRESHOLD=0.35

GEOIP_URL=http://ip-api.com/json
GEO_MAX_MATCH_KM=150

# RRR mobile app — optional Supabase JWT verification
SUPABASE_URL=
SUPABASE_ANON_KEY=
ALLOWED_ORIGINS=
AUTH_REQUIRED=false
